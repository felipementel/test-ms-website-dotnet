<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<ContainerRepository>canal-deploy</ContainerRepository>
		<UserSecretsId>f37df685-f024-46d8-be4d-fbf46c25d53f</UserSecretsId>
		<DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
		<DockerfileContext>..\..</DockerfileContext>
		<VersionPrefix>rc</VersionPrefix>
		<Version>0.1.2</Version>
		<VersionSuffix>alfa</VersionSuffix>

	    <!-- Habilita geração do OpenAPI durante o build -->
	    <OpenApiGenerateDocuments>true</OpenApiGenerateDocuments>
	    <OpenApiGenerateDocumentsOnBuild>true</OpenApiGenerateDocumentsOnBuild>

	    <!-- Onde o arquivo será gerado -->
	    <OpenApiDocumentsDirectory>../../output_build/open-api</OpenApiDocumentsDirectory>

	    <!-- Nome do arquivo gerado: openapi.json -->
	    <OpenApiGenerateDocumentsOptions>--file-name openapi</OpenApiGenerateDocumentsOptions>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.VisualStudio.Azure.Containers.Tools.Targets" Version="1.23.0" />
		<PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
	    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.8" />	
	    <PackageReference Include="Microsoft.Extensions.ApiDescription.Server" Version="10.0.8">
	      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
	      <PrivateAssets>all</PrivateAssets>
	    </PackageReference>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Usuarios.Adapters\Usuarios.Adapters.csproj" />
		<ProjectReference Include="..\Usuarios.Application\Usuarios.Application.csproj" />
	</ItemGroup>

</Project>
